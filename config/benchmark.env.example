# Copie este arquivo para:
#   local/benchmark.env
# e ajuste os caminhos/comandos da sua máquina.

# Diretórios dos projetos externos
LEGACY_PROJECT_DIR=/caminho/para/agentico_poc_fastapi
SIMPLE_PY_PROJECT_DIR=/caminho/para/poc-llm-ufc-simple-py-
SPRING_PROJECT_DIR=/caminho/para/poc-llm-ufc-simples

# Endpoints esperados
SPRING_BASE_URL=http://localhost:8080
SPRING_READY_URL=http://localhost:8080/swagger-ui.html

LEGACY_BOOTSTRAP_BASE_URL=http://localhost:8000
LEGACY_READY_URL=http://localhost:8000/health

SIMPLE_PY_BOOTSTRAP_BASE_URL=http://localhost:8000
SIMPLE_PY_READY_URL=http://localhost:8000/docs

# Comandos de start opcionais
# SPRING_START_CMD=exec ./mvnw spring-boot:run
# SIMPLE_PY_API_MULTIWORKER_CMD=exec uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 2
# LEGACY_API_MULTIWORKER_CMD=exec uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2

# Coleta de metricas
METRICS_ENABLED=true
METRICS_PYTHON_BIN=python3
# O interpretador acima precisa ter psutil instalado.

# Redis opcional
REDIS_REQUIRED=true
# REDIS_START_CMD=exec redis-server

# Banco legado opcional para reset/bootstrap
LEGACY_DB_HOST=localhost
LEGACY_DB_PORT=5432
LEGACY_DB_NAME=llm_ufc
LEGACY_DB_USER=postgres
# LEGACY_DB_PASSWORD=sua_senha

# Defaults da carga
DEFAULT_RUN_FLOW=suite
DEFAULT_API_WORKERS=1
DEFAULT_CELERY_WORKERS=1
DEFAULT_JMETER_THREADS=30
DEFAULT_JMETER_LOOPS=30
DEFAULT_JMETER_RAMP_SECONDS=60
DEFAULT_JMETER_DELAY_MS=50
